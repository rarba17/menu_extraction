# =============================================================================
# .env.example - Environment Variables Template
# =============================================================================
# COPY this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development                     # 'development' or 'production'
APP_VERSION=latest                      # Docker image tag

# ---------------------------------------------------------------------------
# Google Gemini API
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here # Required: get from https://ai.google.dev/

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000         # Used by frontend to reach backend
LOG_LEVEL=info                          # debug | info | warning | error
WEB_CONCURRENCY=2                       # Number of gunicorn workers
MAX_WORKERS=4                           # Max cap for worker count
MAX_FILE_SIZE=10485760                  # 10MB in bytes

# Gunicorn tuning (production)
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
GUNICORN_GRACEFUL_TIMEOUT=30

# ---------------------------------------------------------------------------
# Frontend (Streamlit)
# ---------------------------------------------------------------------------
FRONTEND_PORT=8501

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb
REDIS_PASSWORD=                         # Set a strong password for production!
REDIS_LOG_LEVEL=notice

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=./docker/nginx/certs     # Path to SSL certificate directory

# ---------------------------------------------------------------------------
# Scaling (production)
# ---------------------------------------------------------------------------
BACKEND_REPLICAS=1                      # Number of backend container replicas
